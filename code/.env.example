# Database (Railway PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Redis (Railway Redis) — used for rate limiting and Free/Busy caching
REDIS_URL=redis://default:password@host:6379

# Google Calendar OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Brevo transactional email
BREVO_API_KEY=
BREVO_SENDER_EMAIL=info@carolinataxstrategy.com
BREVO_SENDER_NAME=Carolina Tax Strategy
ADMIN_NOTIFY_EMAIL=info@carolinataxstrategy.com

# Object storage — reserved for future use (not used yet)
CTS_BUCKET_NAME=
CTS_ENDPOINT=
CTS_ACCESS_KEY_ID=
CTS_SECRET_ACCESS_KEY=
CTS_DEFAULT_REGION=

# Server
PORT=3000
# Public base URL of the deployed app (used for Google OAuth redirect URIs)
APP_URL=https://your-app.up.railway.app
